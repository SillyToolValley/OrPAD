{
  "name": "orpad",
  "version": "1.0.0-beta.6",
  "productName": "OrPAD",
  "description": "OrPAD (Orchestration Pipeline Authoring & Development) is a local-first multi-format workspace for Markdown, structured data, diagrams, AI actions, MCP tools, terminals, Git status, and web/PWA workflows.",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "build:renderer": "node scripts/build-renderer.js",
    "build:web": "node scripts/build-web.js",
    "build:web:min": "node scripts/build-web.js --minify",
    "prestart": "npm run build:renderer",
    "dist": "npm run dist:win",
    "dist:win": "npm run build:renderer && electron-builder --win --publish=never",
    "dist:mac": "npm run build:renderer && electron-builder --mac --publish=never",
    "dist:all": "npm run build:renderer && electron-builder -mw --publish=never",
    "dist:portable": "npm run build:renderer && electron-builder --win portable --publish=never",
    "release:write-updater-key": "node scripts/write-updater-public-key.mjs",
    "release:manifest": "node scripts/create-release-manifest.mjs && npm run release:check-manifest",
    "release:check-manifest": "node scripts/check-release-manifest.mjs",
    "release:verify": "npm run release:check-manifest",
    "build:icons": "png2icons assets/icon.png assets/icon -allwe -hm",
    "size": "node scripts/bundle-size.mjs",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "diagnostics:electron": "node -e \"const fs=require('fs');const missing=[];const load=(id)=>{try{return require(id)}catch(err){missing.push(id);return null}};const electron=load('electron');const electronPkg=load('electron/package.json');const playwrightPkg=load('@playwright/test/package.json');const playwright=load('playwright');const exe=typeof electron==='string'?electron:null;const browsers={};if(playwright){for(const name of ['chromium','firefox','webkit']){try{const browserExe=playwright[name].executablePath();browsers[name]={executable:browserExe,exists:fs.existsSync(browserExe)}}catch(err){browsers[name]={error:err.message}}}}const diagnostics={node:process.version,platform:process.platform,arch:process.arch,electron:electronPkg&&electronPkg.version||null,electronExecutable:exe,playwright:playwrightPkg&&playwrightPkg.version||null,playwrightBrowsersPath:process.env.PLAYWRIGHT_BROWSERS_PATH||'default',playwrightBrowsers:browsers,missingPrerequisites:missing};console.log(JSON.stringify(diagnostics,null,2));const missingBrowsers=Object.entries(browsers).filter(([,info])=>info.executable&&!info.exists).map(([name])=>name);if(missingBrowsers.length){console.error('Missing Playwright browser executables: '+missingBrowsers.join(', '))}if(missing.length){console.error('Missing Electron/Playwright prerequisites: '+missing.join(', '));process.exit(1)}if(exe&&!fs.existsSync(exe)){console.error('Electron executable missing: '+exe);process.exit(1)}\"",
    "test:electron": "npm run test:electron:smoke",
    "test:electron:smoke": "npm run diagnostics:electron && playwright test --project=electron --workers=1",
    "test:electron:soak": "npm run diagnostics:electron && playwright test --project=electron --workers=1 --repeat-each=2",
    "test:web": "npm run build:web:min && playwright test --project=web-chromium",
    "test:web:compat": "npm run build:web:min && playwright test --project=web-chromium --project=web-firefox --project=web-webkit",
    "debug:electron": "node scripts/debug-electron-ui.mjs",
    "debug:electron:shot": "node scripts/debug-electron-ui.mjs --shot-only",
    "audit:orpad-node-schemas": "node scripts/audit-orpad-node-schemas.mjs",
    "audit:orpad-queue": "node scripts/audit-orpad-workqueue.mjs",
    "audit:orpad-run": "node scripts/audit-orpad-run.mjs",
    "lh": "npx --yes lighthouse http://localhost:4173 --preset=pwa --chrome-flags='--headless=new' --quiet --output=html --output-path=./lighthouse-report.html"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.0",
    "playwright": "1.59.1",
    "png2icons": "^2.0.1",
    "workbox-cli": "^7.4.0",
    "workbox-window": "^7.4.0"
  },
  "dependencies": {
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language-data": "^6.5.2",
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "@isomorphic-git/lightning-fs": "^4.6.2",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@replit/codemirror-vim": "^6.3.0",
    "@sentry/browser": "^10.50.0",
    "@sentry/electron": "^7.11.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-unicode-graphemes": "^0.4.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "3d-force-graph": "^1.80.0",
    "ajv": "^6.14.0",
    "codemirror": "^6.0.2",
    "dompurify": "^3.4.0",
    "highlight.js": "^11.11.0",
    "ini": "^6.0.0",
    "isomorphic-git": "^1.37.5",
    "js-yaml": "^4.1.1",
    "jsonpath-plus": "^10.4.0",
    "jsonrepair": "^3.14.0",
    "katex": "^0.16.45",
    "lz-string": "^1.5.0",
    "marked": "^15.0.0",
    "marked-gfm-heading-id": "^4.1.0",
    "marked-highlight": "^2.2.0",
    "mermaid": "^11.14.0",
    "papaparse": "^5.5.3",
    "plausible-tracker": "^0.3.9",
    "smol-toml": "^1.6.1",
    "svg-pan-zoom": "^3.6.2",
    "three": "^0.184.0",
    "turndown": "^7.2.4",
    "v8-compile-cache": "2.3.0"
  }
}
