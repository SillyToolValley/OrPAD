{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "orpad.candidateProposal.v1",
  "title": "OrPAD Candidate Proposal",
  "type": "object",
  "required": [
    "schemaVersion",
    "proposalId",
    "sourceNode",
    "title",
    "fingerprint",
    "evidence",
    "acceptanceCriteria"
  ],
  "properties": {
    "schemaVersion": {
      "enum": ["orpad.candidateProposal.v1"]
    },
    "proposalId": {
      "type": "string",
      "minLength": 1
    },
    "suggestedWorkItemId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,190}$"
    },
    "sourceNode": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "fingerprint": {
      "type": "string",
      "minLength": 1
    },
    "contentArea": {
      "type": "string"
    },
    "issueType": {
      "type": "string"
    },
    "severity": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "acceptanceCriteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "sourceOfTruthTargets": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "targetFiles": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "coverageEvidenceIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
