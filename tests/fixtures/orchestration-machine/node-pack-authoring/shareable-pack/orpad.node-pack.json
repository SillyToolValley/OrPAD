{
  "kind": "orpad.nodePack",
  "schemaVersion": "1.0",
  "id": "community.shareable-review",
  "name": "Shareable Review Pack",
  "version": "0.1.0",
  "description": "A minimal declarative Package fixture for registry draft generation.",
  "origin": "community",
  "author": {
    "name": "Fixture Author",
    "repository": "https://github.com/example/orpad-shareable-review"
  },
  "license": "MIT",
  "trustLevel": "community",
  "compatibility": {
    "orpad": ">=1.0.0-beta.3",
    "packFormat": "orpad.nodePack.v1"
  },
  "capabilities": [
    "read.workspace"
  ],
  "nodes": [
    {
      "type": "community.shareableReview.note",
      "path": "nodes/review-note.or-node",
      "runtimeHandlerKind": "metadata-only",
      "capabilities": [
        "read.workspace"
      ]
    }
  ],
  "skills": [
    {
      "id": "shareable-review-skill",
      "path": "skills/shareable-review.md",
      "description": "Review checklist guidance for shareable pack authoring."
    }
  ],
  "keywords": [
    "review",
    "sharing"
  ],
  "categories": [
    "Authoring"
  ]
}
