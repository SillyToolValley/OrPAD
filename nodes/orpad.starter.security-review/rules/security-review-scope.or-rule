{
  "kind": "orpad.rule",
  "version": "1.0",
  "id": "security-review-scope",
  "include": [
    "SECURITY.md",
    "src/main/**",
    "src/renderer/**",
    "tests/e2e/*xss*",
    "tests/e2e/*key*",
    "tests/e2e/*authority*"
  ],
  "exclude": [
    ".env",
    "**/*secret*",
    "**/*token*",
    "**/*.pem",
    "**/*.key",
    "dist/**"
  ]
}
