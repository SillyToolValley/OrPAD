{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "orpad.workerResult.v1",
  "title": "OrPAD Adapter Result",
  "type": "object",
  "required": [
    "schemaVersion",
    "adapterCallId",
    "attemptId",
    "idempotencyKey",
    "status",
    "summary",
    "artifacts"
  ],
  "properties": {
    "schemaVersion": {
      "enum": ["orpad.workerResult.v1"]
    },
    "adapterCallId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,190}$"
    },
    "attemptId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,190}$"
    },
    "idempotencyKey": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "done",
        "blocked",
        "queued",
        "requeued",
        "failed",
        "approval-required",
        "rejected"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "patchArtifact": {
      "type": "string",
      "pattern": "^$|^(?!/)(?![A-Za-z]:/)(?!.*\\\\)(?!.*(^|/)\\.($|/))(?!.*(^|/)\\.\\.($|/))(?!.*//).+"
    },
    "changedFiles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(?!/)(?![A-Za-z]:/)(?!.*\\\\)(?!.*(^|/)\\.($|/))(?!.*(^|/)\\.\\.($|/))(?!.*//).+"
      }
    },
    "candidateProposals": {
      "type": "array",
      "items": {
        "$ref": "orpad.candidateProposal.v1"
      }
    },
    "triageTransitions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["itemId", "toState"],
        "properties": {
          "itemId": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,190}$"
          },
          "toState": {
            "enum": ["queued", "blocked", "rejected"]
          },
          "reason": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "emptyPass": {
      "type": "object",
      "properties": {
        "reason": {
          "type": "string"
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": true
    },
    "deferredReason": {
      "type": "string"
    },
    "usage": {
      "type": "object",
      "properties": {
        "promptTokens": {
          "type": "integer",
          "minimum": 0
        },
        "completionTokens": {
          "type": "integer",
          "minimum": 0
        },
        "totalTokens": {
          "type": "integer",
          "minimum": 0
        },
        "costEstimateUsd": {
          "type": "number",
          "minimum": 0
        },
        "currency": {
          "enum": ["USD"]
        }
      },
      "additionalProperties": true
    },
    "cacheHit": {
      "type": "boolean"
    },
    "routingDecision": {
      "type": "object",
      "required": ["providerId", "model"],
      "properties": {
        "providerId": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "family": {
          "enum": ["api", "cli"]
        },
        "fallbackChainConsumed": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
