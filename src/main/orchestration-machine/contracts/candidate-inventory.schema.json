{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "orpad.machineCandidateInventory.v1",
  "title": "OrPAD Machine Candidate Inventory",
  "type": "object",
  "required": [
    "schemaVersion",
    "runId",
    "createdAt",
    "sourceEventSequence",
    "selectedProbeNodes",
    "candidateCount",
    "emptyPassCount",
    "items"
  ],
  "properties": {
    "schemaVersion": {
      "enum": ["orpad.machineCandidateInventory.v1"]
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "sourceEventSequence": {
      "type": "integer",
      "minimum": 0
    },
    "selectedProbeNodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "candidateCount": {
      "type": "integer",
      "minimum": 0
    },
    "emptyPassCount": {
      "type": "integer",
      "minimum": 0
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "status",
          "nodePath",
          "evidence"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": ["candidate", "empty-pass"]
          },
          "nodePath": {
            "type": "string",
            "minLength": 1
          },
          "proposalId": {
            "type": "string"
          },
          "suggestedWorkItemId": {
            "type": "string"
          },
          "fingerprint": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "severity": {
            "type": "string"
          },
          "confidence": {
            "type": ["number", "null"],
            "minimum": 0,
            "maximum": 1
          },
          "reason": {
            "type": "string"
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "anyOf": [
                {
                  "type": "string",
                  "minLength": 1
                },
                {
                  "type": "object",
                  "additionalProperties": true
                }
              ]
            }
          },
          "sourceOfTruthTargets": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
