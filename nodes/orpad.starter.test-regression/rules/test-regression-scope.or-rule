{
  "kind": "orpad.rule",
  "version": "1.0",
  "id": "test-regression-scope",
  "include": [
    "tests/**",
    "test/**",
    "__tests__/**",
    "src/**",
    "package.json",
    "package-lock.json",
    "playwright.config.*",
    "scripts/**",
    "**/*.csproj"
  ],
  "exclude": [
    "node_modules/**",
    "dist/**",
    "release/**",
    "out/**",
    "**/bin/**",
    "**/obj/**",
    ".env",
    "**/*secret*",
    "**/*token*"
  ]
}
