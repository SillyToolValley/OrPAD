{
  "pipeline": {
    "schemaVersion": "orpad.machineAdapter.v2",
    "enabled": true,
    "default": {
      "family": "api",
      "providerId": "anthropic",
      "model": "claude-3-5-sonnet-latest",
      "qualityTier": "standard",
      "sessionStrategy": "none",
      "toolPolicy": "none",
      "sandbox": null,
      "approvalPolicy": "never",
      "timeoutMs": 600000,
      "ephemeral": true
    },
    "fallback": [
      {
        "family": "api",
        "providerId": "openai",
        "model": "gpt-4o-mini",
        "reason": "cost"
      }
    ]
  },
  "nodeOverrides": {
    "main/probe": {
      "family": "cli",
      "providerId": "codex-cli",
      "model": "codex",
      "qualityTier": "standard",
      "sandbox": "read-only"
    },
    "main/worker": null
  }
}
