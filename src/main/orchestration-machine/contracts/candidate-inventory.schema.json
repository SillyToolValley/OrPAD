{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "orpad.machineCandidateInventory.v1",
  "title": "OrPAD Machine Candidate Inventory",
  "type": "object",
  "required": [
    "schemaVersion",
    "runId",
    "createdAt",
    "sourceEventSequence",
    "selectedProbeNodes",
    "candidateCount",
    "emptyPassCount",
    "items"
  ],
  "properties": {
    "schemaVersion": {
      "enum": ["orpad.machineCandidateInventory.v1"]
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "sourceEventSequence": {
      "type": "integer",
      "minimum": 0
    },
    "selectedProbeNodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "candidateCount": {
      "type": "integer",
      "minimum": 0
    },
    "emptyPassCount": {
      "type": "integer",
      "minimum": 0
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "status",
          "nodePath",
          "evidence",
          "evidenceIds",
          "targetIds",
          "riskCheckIds",
          "checkResult",
          "inspectedTargets"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": ["candidate", "empty-pass"]
          },
          "nodePath": {
            "type": "string",
            "minLength": 1
          },
          "proposalId": {
            "type": "string"
          },
          "suggestedWorkItemId": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,190}$"
          },
          "fingerprint": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "severity": {
            "type": "string"
          },
          "confidence": {
            "type": ["number", "null"],
            "minimum": 0,
            "maximum": 1
          },
          "reason": {
            "type": "string"
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "anyOf": [
                {
                  "type": "string",
                  "minLength": 1
                },
                {
                  "type": "object",
                  "additionalProperties": true
                }
              ]
            }
          },
          "evidenceIds": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "targetIds": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "riskCheckIds": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "checkResult": {
            "enum": ["candidate", "empty-pass", "deferred", "blocked"]
          },
          "inspectedTargets": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["targetId", "status", "evidenceIds"],
              "properties": {
                "targetId": {
                  "type": "string",
                  "minLength": 1
                },
                "status": {
                  "type": "string",
                  "minLength": 1
                },
                "evidenceIds": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              },
              "additionalProperties": true
            }
          },
          "negativeCheck": {
            "type": "object",
            "required": ["method", "expected", "observed", "evidenceIds"],
            "properties": {
              "method": {
                "type": "string",
                "minLength": 1
              },
              "expected": {
                "type": "string",
                "minLength": 1
              },
              "observed": {
                "type": "string",
                "minLength": 1
              },
              "evidenceIds": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "additionalProperties": true
          },
          "sourceOfTruthTargets": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "status": {
                  "const": "empty-pass"
                }
              }
            },
            "then": {
              "required": ["reason", "negativeCheck"]
            }
          }
        ],
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
