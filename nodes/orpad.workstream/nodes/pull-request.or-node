{
  "kind": "orpad.node",
  "schemaVersion": "1.0",
  "type": "orpad.pullRequest",
  "label": "Pull Request",
  "category": "Workstream",
  "description": "Opens a real pull request from changes a patch-review node already applied to the canonical workspace: creates a branch, commits, pushes, and runs `gh pr create`, then optionally polls CI checks and gates the run. Machine-executed (no LLM); opt-in and gh-authenticated. Failures block the run with typed pull-request evidence instead of warn-passing.",
  "inputs": [
    {
      "name": "input",
      "type": "control"
    }
  ],
  "outputs": [
    {
      "name": "opened",
      "type": "control"
    }
  ],
  "configSchema": {
    "type": "object",
    "required": ["title"],
    "properties": {
      "title": {
        "type": "string",
        "description": "Pull request title."
      },
      "body": {
        "type": "string",
        "description": "Pull request body/description."
      },
      "branch": {
        "type": "string",
        "description": "Branch to create for the PR; defaults to orpad/pr-<node>."
      },
      "base": {
        "type": "string",
        "description": "Base branch for the PR; defaults to the repository default."
      },
      "remote": {
        "type": "string",
        "default": "origin"
      },
      "draft": {
        "type": "boolean",
        "default": false
      },
      "push": {
        "type": "boolean",
        "default": true
      },
      "commitMessage": {
        "type": "string"
      },
      "commitPaths": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Pathspecs to stage; defaults to all changes (-A)."
      },
      "requireChecks": {
        "type": "boolean",
        "default": false,
        "description": "Poll `gh pr checks` and gate the run on CI status."
      },
      "pollIntervalMs": {
        "type": "integer",
        "minimum": 1
      },
      "checksMaxWaitMs": {
        "type": "integer",
        "minimum": 1
      },
      "onFail": {
        "type": "string",
        "enum": ["block", "warn"],
        "default": "block"
      },
      "timeoutMs": {
        "type": "integer",
        "minimum": 1
      }
    }
  },
  "capabilities": ["read.workspace", "write.workspace", "write.runArtifacts"]
}
