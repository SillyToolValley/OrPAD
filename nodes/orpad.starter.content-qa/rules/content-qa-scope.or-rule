{
  "kind": "orpad.rule",
  "version": "1.0",
  "id": "content-qa-scope",
  "include": [
    "README.md",
    "docs/**",
    "slides/**",
    "tutorials/**",
    "lessons/**",
    "courses/**",
    "**/*.md",
    "src/locales/**",
    "locales/**",
    "src/renderer/templates/**"
  ],
  "exclude": [
    "node_modules/**",
    "dist/**",
    ".env",
    "**/*secret*"
  ]
}
