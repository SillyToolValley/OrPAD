{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "orpad.workItem.v1",
  "title": "OrPAD Work Item",
  "type": "object",
  "required": [
    "id",
    "schemaVersion",
    "state",
    "title",
    "sourceNode",
    "contentArea",
    "issueType",
    "severity",
    "confidence",
    "fingerprint",
    "evidence",
    "acceptanceCriteria",
    "userImpact",
    "reproSteps",
    "expectedBehavior",
    "actualBehavior",
    "sourceOfTruthTargets",
    "verificationPlan",
    "coverageEvidenceIds",
    "approvalRequired",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "schemaVersion": {
      "enum": ["orpad.workItem.v1"]
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,190}$"
    },
    "state": {
      "enum": ["candidate", "queued", "claimed", "done", "blocked", "rejected"]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "sourceNode": {
      "type": "string",
      "minLength": 1
    },
    "contentArea": {
      "type": "string",
      "minLength": 1
    },
    "issueType": {
      "type": "string",
      "minLength": 1
    },
    "severity": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "fingerprint": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "acceptanceCriteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "userImpact": {
      "type": "string",
      "minLength": 1
    },
    "reproSteps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "expectedBehavior": {
      "type": "string",
      "minLength": 1
    },
    "actualBehavior": {
      "type": "string",
      "minLength": 1
    },
    "sourceOfTruthTargets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "verificationPlan": {
      "type": "string",
      "minLength": 1
    },
    "coverageEvidenceIds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "approvalRequired": {
      "type": "boolean"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": true
}
