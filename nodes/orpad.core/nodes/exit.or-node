{
  "kind": "orpad.node",
  "schemaVersion": "1.0",
  "type": "orpad.exit",
  "title": "Exit",
  "description": "Marks the closing point for an OrPAD graph.",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "summary": {
        "type": "string",
        "minLength": 1
      }
    },
    "required": ["summary"]
  }
}
